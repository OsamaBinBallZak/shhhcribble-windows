<Window x:Class="Shhhcribble.Windows.UI.LozengeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        IsHitTestVisible="False">
    <Border CornerRadius="18" Padding="18,11" Background="#E6202124">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.45" Color="Black"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Canvas x:Name="Waves" Width="52" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="Label"
                       Foreground="#F5F5F7"
                       FontSize="14"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Text="Listening…"/>
        </StackPanel>
    </Border>
</Window>
