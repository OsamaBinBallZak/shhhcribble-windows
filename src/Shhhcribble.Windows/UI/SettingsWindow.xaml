<Window x:Class="Shhhcribble.Windows.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shhhcribble Settings"
        Width="440" Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- GroupBox header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <!-- Footer caption style -->
        <Style x:Key="FooterCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <!-- GroupBox style with visible border -->
        <Style x:Key="SectionGroupBox" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10,8,10,10"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Style="{StaticResource SectionHeaderStyle}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,12,16,16">

            <!-- ══════════════════════════════════════════ -->
            <!-- 1. Transcription Model                     -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="Transcription Model" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <ComboBox x:Name="ModelCombo" DisplayMemberPath="DisplayName" Margin="0,0,0,6"/>

                    <!-- Inline busy warning — hidden by default -->
                    <Border x:Name="BusyWarningBorder"
                            Visibility="Collapsed"
                            Background="#1FF2A81A"
                            BorderBrush="#47F2A81A"
                            BorderThickness="0.6"
                            CornerRadius="8"
                            Padding="11,9,11,9"
                            Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F2A81A" VerticalAlignment="Top"
                                       Margin="0,1,8,0"/>
                            <TextBlock x:Name="BusyWarningText"
                                       Text="Stop the current recording to change the transcription model."
                                       FontSize="11" Foreground="#D9000000"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Model loading/ready/failed status -->
                    <Grid x:Name="ModelStatusRow" Visibility="Collapsed">
                        <!-- Loading spinner row -->
                        <StackPanel x:Name="ModelStatusLoading" Orientation="Horizontal" Visibility="Collapsed">
                            <ProgressBar x:Name="ModelStatusSpinner" IsIndeterminate="True"
                                         Width="80" Height="4" Margin="0,0,6,0"
                                         VerticalAlignment="Center"/>
                            <TextBlock x:Name="ModelStatusText" FontSize="11" Foreground="#999999"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Non-loading status row -->
                        <TextBlock x:Name="ModelStatusTextSimple" FontSize="11"
                                   Foreground="#999999" Visibility="Collapsed"
                                   TextWrapping="Wrap"/>
                        <!-- Error status row -->
                        <StackPanel x:Name="ModelStatusError" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="&#x26A0; " FontSize="11" FontWeight="SemiBold"
                                       Foreground="#CC3333" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ModelStatusErrorText" FontSize="11" Foreground="#CC3333"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource FooterCaptionStyle}"
                               Text="Models are downloaded once and cached on your PC.&#x0a;Parakeet V3 (multilingual) is recommended for most users."/>
                </StackPanel>
            </GroupBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- 2. Recording Shortcut                      -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="Recording Shortcut" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <ComboBox x:Name="HotkeyCombo" DisplayMemberPath="Label" Margin="0,0,0,6"/>
                    <TextBlock x:Name="HotkeyFooter"
                               Style="{StaticResource FooterCaptionStyle}"
                               TextWrapping="Wrap"
                               Text="Tap the shortcut to start recording and tap again to stop, or hold it and release to transcribe — Shhhcribble picks the mode based on how long you hold."/>
                </StackPanel>
            </GroupBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- 3. Options                                  -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="Options" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Activation mode" VerticalAlignment="Center"
                                   Width="160" FontSize="12"/>
                        <ComboBox x:Name="ActivationCombo" DisplayMemberPath="Label" Width="220"/>
                    </StackPanel>
                    <CheckBox x:Name="FillerCheck" Content="Strip filler words (um, uh, you know…)"
                              Margin="0,6,0,4"/>
                    <CheckBox x:Name="PauseMusicCheck" Content="Pause music while recording"
                              Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource FooterCaptionStyle}">
                        Basic filler-word removal ("um", "uh", "hmm") is applied automatically when enabled.&#x0a;Any SMTC-compatible music player (Spotify, browsers, Groove) pauses automatically while you dictate and resumes when recording ends.
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- 4. Personal Dictionary                     -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="Personal Dictionary" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <!-- Empty-state hint -->
                    <TextBlock x:Name="DictEmptyHint"
                               Text="No entries yet — add names or jargon the transcriber gets wrong."
                               Style="{StaticResource FooterCaptionStyle}"
                               Visibility="Collapsed"
                               Margin="0,0,0,8"/>

                    <!-- Dictionary DataGrid -->
                    <DataGrid x:Name="DictGrid" AutoGenerateColumns="False"
                              CanUserAddRows="True" CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MinHeight="80" MaxHeight="200"
                              Margin="0,0,0,6"
                              SelectionMode="Single"
                              RowEditEnding="OnRowEditEnding"
                              CellEditEnding="OnCellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Phrase" Binding="{Binding Phrase, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Case" Binding="{Binding CaseSensitive}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Dictionary action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="MoveUpButton" Content="▲ Up" Width="60"
                                Margin="0,0,6,0" IsEnabled="False"
                                Click="OnMoveUp" ToolTip="Move entry up"/>
                        <Button x:Name="MoveDownButton" Content="▼ Down" Width="70"
                                Margin="0,0,6,0" IsEnabled="False"
                                Click="OnMoveDown" ToolTip="Move entry down"/>
                        <Button x:Name="RemoveRowButton" Content="Remove" Width="70"
                                Margin="0,0,0,0"
                                Click="OnRemoveRow" ToolTip="Remove selected entry"/>
                    </StackPanel>

                    <!-- Dictionary footer caption -->
                    <TextBlock Style="{StaticResource FooterCaptionStyle}">
                        Replacements are applied to the raw transcript in list order. Whole words only — "cat" never matches inside "catalog".
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- 5. Permissions                             -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="Permissions" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <!-- Microphone row -->
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <TextBlock Grid.Column="0" Text="&#x1F3A4;" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <!-- Label block -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Microphone" FontWeight="Medium" FontSize="12"/>
                            <TextBlock Text="Required to record your voice"
                                       FontSize="11" Foreground="#999999"/>
                        </StackPanel>

                        <!-- Status / button -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock x:Name="MicGrantedLabel" Text="Granted"
                                       Foreground="#2E7D32" FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            <Button x:Name="MicSettingsButton"
                                    Content="Open Settings"
                                    Padding="8,2" FontSize="11"
                                    Click="OnOpenMicSettings"
                                    Visibility="Visible"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- ══════════════════════════════════════════ -->
            <!-- 6. About                                   -->
            <!-- ══════════════════════════════════════════ -->
            <GroupBox Header="About" Style="{StaticResource SectionGroupBox}">
                <StackPanel>
                    <!-- App name + version row -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Shhhcribble"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="VersionLabel"
                                   FontSize="12" Foreground="#999999"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Shortcut hint caption -->
                    <TextBlock x:Name="AboutShortcutHint"
                               Style="{StaticResource FooterCaptionStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <!-- Credits + kaomoji -->
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="this app was crafted by a human named Hendri with chief vibes officer Tiuri whispering ideas in his ear. both humans. probably."
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="11" Foreground="#999999"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Column="1"
                                   Text="( ᴗ ͜ʖ ᴗ)"
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="11"
                                   Opacity="0.7"
                                   Foreground="#999999"
                                   VerticalAlignment="Bottom"
                                   Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
